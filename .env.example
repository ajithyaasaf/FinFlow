# ============================================================================
# FINFLOW ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your values

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# Get these from your Supabase project: Settings > API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------------------------
# CRON JOB SECURITY (Required for production)
# Generate a secure random string for cron job authentication
# ----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-key

# ----------------------------------------------------------------------------
# OPTIONAL: EMAIL INTEGRATION
# For sending Top-Up offer notifications
# Get API key from https://resend.com
# ----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxx

# ----------------------------------------------------------------------------
# OPTIONAL: STORAGE CONFIGURATION
# Default: Supabase Storage is used automatically
# Only needed if using external storage provider
# ----------------------------------------------------------------------------
# STORAGE_BUCKET=loan-documents

# ============================================================================
# NOTES:
# - Never commit .env.local to version control
# - All NEXT_PUBLIC_ prefixed variables are exposed to the browser
# - Keep CRON_SECRET secure; it's used to protect scheduled job endpoints
# ============================================================================
